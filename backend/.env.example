# LINE channel (เอามาจาก LINE Developers Console)
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token

# PostgreSQL
DATABASE_URL=postgres://line:line@localhost:5432/line_task_manager

# server
PORT=3000

# คอมมานด์คีย์เวิร์ดที่ใช้ดักว่าเป็น task
TASK_KEYWORD=/task

# --- ความปลอดภัย (production ควรตั้งทั้งคู่) ---
# รหัสผ่านเข้าบอร์ด — ไม่ตั้ง = ปิด auth (โหมด dev)
#BOARD_PASSWORD=change_me
# จำกัด origin ที่เรียก API/WebSocket ได้ — ไม่ตั้ง = * (โหมด dev)
#CORS_ORIGIN=https://board.example.com

# --- การแจ้งเตือนกลับเข้ากลุ่ม LINE ---
# สถานะที่จะ push เข้ากลุ่ม (คั่นด้วย ,) — ลดลงเพื่อประหยัด quota OA เช่น NOTIFY_STATUSES=done
NOTIFY_STATUSES=todo,in_process,test,done
# แจ้งตอนมีคนรับงาน (true/false)
NOTIFY_ASSIGN=true

# --- AI ดึงงานจากข้อความธรรมชาติ (optional) ---
# ตั้ง API key แล้วข้อความที่ "ไม่มี" keyword จะถูกส่งให้ Claude คัดกรองว่าเป็นงานไหม
#ANTHROPIC_API_KEY=sk-ant-...
# โมเดลที่ใช้คัดกรอง (default: claude-opus-4-8 — เปลี่ยนเป็น claude-haiku-4-5 ได้ถ้าเน้นประหยัด)
#AI_EXTRACT_MODEL=claude-opus-4-8
